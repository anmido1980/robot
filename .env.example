# T-Invest API
T_INVEST_SANDBOX_TOKEN=your_sandbox_token_here
T_INVEST_PROD_TOKEN=your_prod_token_here_or_leave_empty

# Режим работы: paper | live
TRADING_MODE=paper

# Sandbox endpoint (по умолчанию)
T_INVEST_SANDBOX_HOST=sandbox-invest-public-api.tinkoff.ru:443
T_INVEST_PROD_HOST=invest-public-api.tinkoff.ru:443

# Риск-лимиты
MAX_POSITION_PCT=0.5          # макс. позиция в % от депозита
MAX_DAILY_LOSS_PCT=0.05       # макс. дневной убыток в % от портфеля
MAX_OPEN_POSITIONS=5          # макс. количество одновременно открытых позиций

# Логирование
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_DIR=06-logs

# Telegram-алерты (опционально)
TELEGRAM_BOT_TOKEN=your_bot_token_here_or_leave_empty
TELEGRAM_CHAT_ID=your_chat_id_here_or_leave_empty
